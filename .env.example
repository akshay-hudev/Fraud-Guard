# Database
DATABASE_URL=postgresql://fraud_user:fraud_password@localhost:5432/fraud_detection_db
# For local dev: sqlite:///fraud_detection.db

# API Security
API_KEY_SECRET=your-super-secret-key-change-in-prod
JWT_SECRET=your-jwt-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Model Configuration
MODEL_DIR=models
DATA_DIR=data
PROCESSED_DATA_DIR=data/processed

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/api.log

# API
API_PORT=8000
API_HOST=0.0.0.0
WORKERS=4
RELOAD=false

# Feature Store
FEATURE_CACHE_SIZE=10000
FEATURE_TTL_SECONDS=3600

# Monitoring
ENABLE_PROMETHEUS=true
PROMETHEUS_PORT=9090

# Model Drift
DRIFT_CHECK_INTERVAL_DAYS=7
DRIFT_THRESHOLD_KL_DIVERGENCE=0.15
DRIFT_THRESHOLD_JS_DIVERGENCE=0.1

# Production Flags
DEBUG=false
ENVIRONMENT=development
